<%- include('../../partials/header.ejs', { title: 'User Management' }) %>

<div class="row py-5">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">User Management</h2>
            <p class="text-muted mb-0">Manage platform users and their roles</p>
        </div>
        <a href="/admin/users/add" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-user-plus me-2"></i> Add New User
        </a>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 border-0">User</th>
                                <th class="border-0">Email</th>
                                <th class="border-0">Role</th>
                                <th class="border-0">Joined</th>
                                <th class="text-end pe-4 border-0">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3 py-2">
                                            <img src="/<%= u.profilePic %>" class="rounded-circle shadow-sm" width="40" height="40" onerror="this.src='/assets/images/users/profile.png'">
                                            <span class="fw-bold text-dark"><%= u.userName %></span>
                                        </div>
                                    </td>
                                    <td><small class="text-muted"><%= u.userEmail %></small></td>
                                    <td>
                                        <span class="badge rounded-pill px-3 py-2 <%= u.role === 'admin' ? 'bg-primary' : 'bg-light text-dark' %>">
                                            <%= u.role.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td><small class="text-muted"><%= new Date(u.createdAt).toLocaleDateString() %></small></td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm rounded-pill bg-white overflow-hidden">
                                            <a href="/admin/users/profile/<%= u._id %>" class="btn btn-white btn-sm" title="View Profile"><i class="far fa-eye text-primary"></i></a>
                                            <a href="/admin/users/edit/<%= u._id %>" class="btn btn-white btn-sm" title="Edit User"><i class="far fa-edit text-success"></i></a>
                                            <a href="/admin/users/delete/<%= u._id %>" class="btn btn-white btn-sm" title="Delete User" onclick="return confirm('Are you sure you want to delete this user? This action cannot be undone.')"><i class="far fa-trash-alt text-danger"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer.ejs') %>
