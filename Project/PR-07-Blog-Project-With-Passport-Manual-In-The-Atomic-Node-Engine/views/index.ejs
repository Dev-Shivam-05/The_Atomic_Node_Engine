<%- include('./partials/header.ejs', { title: 'Home' }) %>

<!-- Hero Section -->
<header class="hero-section py-5 mb-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-4">Express Your <span class="text-primary-gradient">Thoughts</span></h1>
                <p class="lead text-muted mb-5">Join our community of writers and readers. Share your stories with the world and connect with fellow creators.</p>
                <div class="d-flex gap-3">
                    <% if (!user) { %>
                        <a href="/register" class="btn btn-primary btn-lg rounded-pill px-5">Join Now</a>
                        <a href="/blog/view-blog" class="btn btn-outline-primary btn-lg rounded-pill px-5">Explore</a>
                    <% } else { %>
                        <a href="/blog/add-blog" class="btn btn-primary btn-lg rounded-pill px-5">Write a Story</a>
                        <a href="/user/dashboard" class="btn btn-outline-primary btn-lg rounded-pill px-5">My Dashboard</a>
                    <% } %>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="/assets/images/background/active-bg.png" alt="Hero Image" class="img-fluid rounded-lg shadow-lg" onerror="this.src='https://images.unsplash.com/photo-1499750310107-5fef28a66643?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'">
            </div>
        </div>
    </div>
</header>

<!-- Stats Section -->
<section class="stats-section py-5 bg-white border-top border-bottom mb-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-4">
                    <div class="h2 fw-bold text-primary mb-1"><%= stats.totalBlogs %></div>
                    <div class="text-muted text-uppercase small fw-bold">Stories Published</div>
                </div>
            </div>
            <div class="col-md-4 border-start border-end border-md-0">
                <div class="p-4">
                    <div class="h2 fw-bold text-primary mb-1"><%= stats.totalUsers %></div>
                    <div class="text-muted text-uppercase small fw-bold">Active Authors</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4">
                    <div class="h2 fw-bold text-primary mb-1">10K+</div>
                    <div class="text-muted text-uppercase small fw-bold">Monthly Readers</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Blogs Section -->
<section class="latest-stories py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="fw-bold mb-2">Latest Stories</h2>
                <p class="text-muted mb-0">Discover the most recent insights from our community</p>
            </div>
            <a href="/blog/view-blog" class="btn btn-link text-primary text-decoration-none fw-bold">
                View All Stories <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            <% if (latestBlogs && latestBlogs.length > 0) { %>
                <% latestBlogs.forEach(blog => { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm hover-up overflow-hidden">
                            <div class="position-relative">
                                <img src="/<%= blog.blogImage %>" class="card-img-top" alt="<%= blog.blogTitle %>" style="height: 200px; object-fit: cover;">
                                <div class="position-absolute top-0 start-0 m-3">
                                    <span class="badge bg-white text-primary shadow-sm rounded-pill px-3 py-2"><%= blog.blogCategory %></span>
                                </div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold mb-3">
                                    <a href="/blog/details/<%= blog._id %>" class="text-dark text-decoration-none"><%= blog.blogTitle %></a>
                                </h5>
                                <p class="card-text text-muted small mb-4 line-clamp-2"><%= blog.blogExcerpt %></p>
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="/<%= blog.author ? blog.author.profilePic : 'assets/images/users/1.jpg' %>" class="rounded-circle" width="24" height="24" onerror="this.src='/assets/images/users/1.jpg'">
                                        <small class="text-muted"><%= blog.author ? blog.author.userName : 'Anonymous' %></small>
                                    </div>
                                    <a href="/blog/details/<%= blog._id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">Read</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No stories yet. Be the first to share your thoughts!</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<style>
    .text-primary-gradient {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .hover-up {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-up:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .rounded-lg {
        border-radius: var(--border-radius-lg) !important;
    }
    .hero-section {
        background-color: var(--white);
    }
</style>

<%- include('./partials/footer.ejs') %>
