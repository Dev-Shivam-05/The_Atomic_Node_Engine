    <main>
        <div class="form-container">
            <h3><i class="bi bi-person-badge-fill"></i> Employee Registration</h3>

            <form method="post" action="/">
                <!-- Employee Name -->
                <div class="form-floating">
                    <input type="text" class="form-control" id="employeeName" placeholder="John Doe" name="employeeName" required>
                    <label for="employeeName"><i class="bi bi-person me-2"></i>Employee Name</label>
                    <div class="form-icon"><i class="bi bi-person-circle"></i></div>
                </div>

                <!-- Employee Email -->
                <div class="form-floating">
                    <input type="email" class="form-control" id="employeeEmail" placeholder="name@example.com" name="employeeEmail" required>
                    <label for="employeeEmail"><i class="bi bi-envelope me-2"></i>Email Address</label>
                    <div class="form-text text-white">We'll never share your email with anyone else.</div>
                </div>

                <!-- Designation -->
                <div class="form-floating">
                    <select class="form-select" id="designation" name="designation" required>
                        <option value="">Select Designation</option>
                        <option value="developer">Software Developer</option>
                        <option value="manager">Project Manager</option>
                        <option value="designer">UI/UX Designer</option>
                        <option value="analyst">Data Analyst</option>
                        <option value="hr">HR Executive</option>
                    </select>
                    <label for="designation"><i class="bi bi-briefcase me-2"></i>Designation</label>
                </div>

                <!-- Salary -->
                <div class="form-floating">
                    <input type="number" class="form-control" id="salary" name="employeeSalary" placeholder="50000" min="0" step="1000">
                    <label for="salary"><i class="bi bi-currency-dollar me-2"></i>Monthly Salary ($)</label>
                    <div class="form-text text-white">Enter gross monthly salary before taxes.</div>
                </div>

                <!-- Checkbox -->
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" value="" id="termsCheck" required>
                    <label class="form-check-label" for="termsCheck">
                        I confirm the details are accurate <i class="bi bi-check-circle-fill text-success ms-1"></i>
                    </label>
                </div>

                <!-- Submit Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-send me-2"></i>Register Employee
                    </button>
                </div>
            </form>
        </div>
    </main>
