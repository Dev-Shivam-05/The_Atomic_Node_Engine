<%- include('../partials/header.ejs') %>
    <!-- ============================================================== -->
    <!-- End Left Sidebar - style you can find in sidebar.scss  -->
    <!-- ============================================================== -->
    <!-- ============================================================== -->
    <!-- Page wrapper  -->
    <!-- ============================================================== -->
    <div class="page-wrapper">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-12 d-flex no-block align-items-center">
                    <h4 class="page-title">Create Product</h4>
                    <div class="ml-auto text-right">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">Product</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Create Product</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Container fluid  -->
        <!-- ============================================================== -->
        <div class="container-fluid">
            <!-- ============================================================== -->
            <!-- Start Page Content -->
            <!-- ============================================================== -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <form class="form-horizontal" action="/product/create-product" method="post"
                            enctype="multipart/form-data">
                            <div class="card-body">
                                <h4 class="card-title">Product Info</h4>
                                <div class="form-group row">
                                    <label for="fname" class="col-sm-3 text-right control-label col-form-label">Product
                                        Name</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="fname" name="productName"
                                            placeholder="Product Name Here">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="lname" class="col-sm-3 text-right control-label col-form-label">Product
                                        Description</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="lname" name="productDescription"
                                            placeholder="Product Description Here">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="lname" class="col-sm-3 text-right control-label col-form-label">Product
                                        Price</label>
                                    <div class="col-sm-9">
                                        <input type="number" class="form-control" id="lname" name="productPrice"
                                            placeholder="Product Price Here" min="1" max="1000000">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="email1" class="col-sm-3 text-right control-label col-form-label">Product
                                        Quantity</label>
                                    <div class="col-sm-9">
                                        <input type="number" class="form-control" id="email1" name="productQuantity"
                                            placeholder="Product Quantity Here" min="1" max="1000000">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="cono1" class="col-sm-3 text-right control-label col-form-label">Product
                                        Image</label>
                                    <div class="col-sm-9">
                                        <input type="file" class="form-control" id="cono1" name="Image" required
                                            accept="image/*">
                                    </div>
                                </div>
                                <!-- Category Dropdown -->
                                <div class="form-group row">
                                    <label for="cono1" class="col-sm-3 text-right control-label col-form-label">Product
                                        Category</label>
                                    <select name="productCategory" id="categorySelect"
                                        onchange="fetchSubcategories(this.value)"
                                        class="form-select form-select-lg form-control bg-light" required>
                                        <option value="" disabled selected>Choose a category...</option>
                                        <% categories.forEach((category)=> { %>
                                            <option value="<%= category._id %>">
                                                <%= category.categoryName %>
                                            </option>
                                            <% }); %>
                                    </select>
                                </div>

                                <div class="form-group row">
                                    <label for="cono1" class="text-right control-label col-form-label">Product
                                        Subcategory</label>
                                    <!-- Subcategory Dropdown -->
                                    <select id="subcategorySelect" name="productSubcategory"
                                        onchange="fetchExtraCategories(this.value)"
                                        class="form-select form-select-lg form-control bg-light mt-2" required>
                                        <option value="" selected disabled>Select Category First</option>
                                    </select>
                                </div>

                                <div class="form-group row">
                                    <label for="cono1" class="text-right control-label col-form-label">Product
                                        ExtraCategory</label>
                                    <!-- ExtraCategory Dropdown -->
                                    <select id="extraCategorySelect" name="productExtraCategory"
                                        class="form-select form-select-lg form-control bg-light mt-2" required>
                                        <option value="" disabled selected>Select SubCategory First</option>
                                        <% extraCategories.forEach((extraCategory)=> { %>
                                            <option value="<%= extraCategory._id %>">
                                                <%= extraCategory.extraCategoryName %>
                                            </option>
                                            <% }); %>
                                    </select>
                                </div>
                            </div>
                            <div class="border-top">
                                <div class="card-body">
                                    <button type="submit" class="btn btn-primary">Submit</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- ============================================================== -->
            <!-- End PAge Content -->
            <!-- ============================================================== -->
            <!-- ============================================================== -->
            <!-- Right sidebar -->
            <!-- ============================================================== -->
            <!-- .right-sidebar -->
            <!-- ============================================================== -->
            <!-- End Right sidebar -->
            <!-- ============================================================== -->
        </div>
        <!-- ============================================================== -->
        <!-- End Container fluid  -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- footer -->
        <!-- ============================================================== -->
        <%- include('../partials/footer.ejs') %>


            <script>
                async function fetchSubcategories(categoryId) {
                    const subCatDropdown = document.getElementById('subcategorySelect');
                    const extraCatDropdown = document.getElementById('extraCategorySelect');

                    // Reset both dependent dropdowns
                    subCatDropdown.innerHTML = '<option value="">Loading...</option>';
                    extraCatDropdown.innerHTML = '<option value="">Select Subcategory First</option>';

                    if (!categoryId) {
                        subCatDropdown.innerHTML = '<option value="">Select Category First</option>';
                        return;
                    }

                    try {
                        const response = await fetch(`/api/sub-category/get-by-category/${categoryId}`);
                        const data = await response.json();

                        subCatDropdown.innerHTML = '<option value="" selected disabled>Select Subcategory</option>';

                        if (data.success && data.subcategories.length > 0) {
                            data.subcategories.forEach(sub => {
                                const option = document.createElement('option');
                                option.value = sub._id;
                                option.textContent = sub.subcategoryName;
                                subCatDropdown.appendChild(option);
                            });
                        } else {
                            subCatDropdown.innerHTML = '<option value="">No Subcategories Found</option>';
                        }
                    } catch (error) {
                        console.error("Error fetching subcategories:", error);
                        subCatDropdown.innerHTML = '<option value="">Error loading subcategories</option>';
                    }
                }

                async function fetchExtraCategories(subCategoryId) {
                    const extraCatDropdown = document.getElementById('extraCategorySelect');

                    extraCatDropdown.innerHTML = '<option value="">Loading...</option>';

                    if (!subCategoryId) {
                        extraCatDropdown.innerHTML = '<option value="">Select Subcategory First</option>';
                        return;
                    }

                    try {
                        const response = await fetch(`/api/extra-category/get-by-sub-category/${subCategoryId}`);
                        const data = await response.json();

                        extraCatDropdown.innerHTML = '<option value="" selected disabled>Select Extra Category</option>';

                        // Note: Check if your API returns "extraCategories" or "subcategories"
                        const list = data.extraCategories || data.subcategories || [];

                        if (data.success && list.length > 0) {
                            list.forEach(extra => {
                                const option = document.createElement('option');
                                option.value = extra._id;
                                option.textContent = extra.extraCategoryName; // Ensure this matches your DB schema
                                extraCatDropdown.appendChild(option);
                            });
                        } else {
                            extraCatDropdown.innerHTML = '<option value="">No Extra Categories Found</option>';
                        }
                    } catch (error) {
                        console.error("Error fetching extraCategories:", error);
                        extraCatDropdown.innerHTML = '<option value="">Error loading extraCategories</option>';
                    }
                }
            </script>
