<!-- views/admin/pages/all-posts.ejs -->

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">All Blog Posts</h4>
        <p class="text-muted mb-0 small">Manage and organize your content</p>
    </div>
    <a href="/admin/posts/create" class="btn btn-primary rounded-pill px-4">
        <i class="mdi mdi-plus me-1"></i> New Post
    </a>
</div>

<!-- Filters Bar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <!-- Left: Status Filters -->
            <div class="d-flex gap-2">
                <a href="/admin/posts" class="btn btn-sm rounded-pill px-3
                    <%= !statusFilter ? 'btn-dark' : 'btn-outline-secondary' %>">
                    All (<%= counts.all %>)
                </a>
                <a href="?status=published" class="btn btn-sm rounded-pill px-3
                    <%= statusFilter === 'published' ? 'btn-success' : 'btn-outline-secondary' %>">
                    Published (<%= counts.published %>)
                </a>
                <a href="?status=draft" class="btn btn-sm rounded-pill px-3
                    <%= statusFilter === 'draft' ? 'btn-warning' : 'btn-outline-secondary' %>">
                    Drafts (<%= counts.drafts %>)
                </a>
            </div>

            <!-- Right: Search + Sort -->
            <div class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm rounded-pill"
                       placeholder="Search posts..." style="width:200px;">
                <select class="form-select form-select-sm rounded-pill" style="width:auto;">
                    <option>Newest first</option>
                    <option>Oldest first</option>
                    <option>Most viewed</option>
                </select>
            </div>

        </div>
    </div>
</div>


<!-- Posts Table -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 small fw-bold text-muted"
                        style="letter-spacing:0.5px;">POST</th>
                    <th class="py-3 small fw-bold text-muted">CATEGORY</th>
                    <th class="py-3 small fw-bold text-muted">STATUS</th>
                    <th class="py-3 small fw-bold text-muted">DATE</th>
                    <th class="py-3 small fw-bold text-muted text-end pe-4">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                <% blogs.forEach(blog => { %>
                    <tr>
                        <!-- Post Info -->
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <img src="/<%= blog.blogImage %>"
                                     class="rounded-3" width="56" height="56"
                                     style="object-fit:cover;">
                                <div>
                                    <h6 class="fw-semibold mb-1 small">
                                        <%= blog.blogTitle %>
                                    </h6>
                                    <small class="text-muted">
                                        by <%= blog.author?.name || 'Admin' %>
                                    </small>
                                </div>
                            </div>
                        </td>

                        <!-- Category -->
                        <td>
                            <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                                <%= blog.blogCategory %>
                            </span>
                        </td>

                        <!-- Status -->
                        <td>
                            <span class="badge rounded-pill px-3 py-2
                                <%= blog.status === 'published'
                                    ? 'bg-success-subtle text-success'
                                    : 'bg-warning-subtle text-warning' %>">
                                <i class="mdi mdi-circle-small"></i>
                                <%= blog.status || 'Published' %>
                            </span>
                        </td>

                        <!-- Date -->
                        <td>
                            <small class="text-muted">
                                <%= new Date(blog.createdAt).toLocaleDateString('en-US',{
                                    month:'short',day:'numeric',year:'numeric'
                                }) %>
                            </small>
                        </td>

                        <!-- Actions -->
                        <td class="text-end pe-4">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/blog/<%= blog._id %>" target="_blank"
                                   class="btn btn-sm btn-outline-secondary rounded-circle"
                                   style="width:34px;height:34px;"
                                   title="View">
                                    <i class="mdi mdi-eye-outline"></i>
                                </a>
                                <a href="/admin/posts/edit/<%= blog._id %>"
                                   class="btn btn-sm btn-outline-primary rounded-circle"
                                   style="width:34px;height:34px;"
                                   title="Edit">
                                    <i class="mdi mdi-pencil-outline"></i>
                                </a>
                                <a href="/admin/posts/delete/<%= blog._id %>"
                                   onclick="return confirm('Delete this post permanently?')"
                                   class="btn btn-sm btn-outline-danger rounded-circle"
                                   style="width:34px;height:34px;"
                                   title="Delete">
                                    <i class="mdi mdi-trash-can-outline"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Table Footer with Pagination -->
    <div class="card-footer bg-white border-top p-3">
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Showing 1-10 of <%= totalPosts %> posts
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled">
                        <a class="page-link rounded-pill">Previous</a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link rounded-pill">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-pill" href="?page=2">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-pill" href="?page=3">3</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-pill" href="?page=2">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>