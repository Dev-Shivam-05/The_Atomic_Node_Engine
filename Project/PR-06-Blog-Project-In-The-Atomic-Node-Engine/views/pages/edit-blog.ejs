<!doctype html>
<html lang="en">

<head>
    <title>Title</title>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <!-- Bootstrap CSS v5.2.1 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
</head>

<body>
    <div class="container">

        <div class="page-wrapper mt-5">

            <!-- Breadcrumb -->
            <div class="page-breadcrumb">
                <div class="row align-items-center">
                    <div class="col-12 d-flex flex-wrap justify-content-between align-items-center">
                        <h4 class="page-title mb-0 fw-bold">✏️ Edit Blog</h4>
                        <div class="ms-auto mt-3 mt-md-0">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb bg-transparent p-0 m-0">
                                    <li class="breadcrumb-item">
                                        <a href="/" class="text-decoration-none">Dashboard</a>
                                    </li>
                                    <li class="breadcrumb-item">
                                        <a href="/blog" class="text-decoration-none">Blogs</a>
                                    </li>
                                    <li class="breadcrumb-item active" aria-current="page">Edit</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Container -->
            <div class="container-fluid">
                <div class="row justify-content-center my-5">
                    <div class="col-xl-8 col-lg-9">
                        <div class="card shadow border-0 rounded-4 overflow-hidden">

                            <!-- Card Header -->
                            <div class="card-header bg-gradient-light py-4 text-center">
                                <h3 class="mb-0 fw-bold text-dark">✏️ Edit Your Blog</h3>
                                <p class="text-muted mb-0">Update and refine your content to perfection.</p>
                            </div>

                            <!-- Form -->
                            <form class="form-horizontal p-4 p-md-5" method="post" action=""
                                enctype="multipart/form-data">

                                <div class="card-body pt-0">

                                    <!-- Section Title -->
                                    <div class="mb-5 pb-3 border-bottom">
                                        <h5 class="fw-bold text-uppercase text-muted small">
                                            BLOG ESSENTIALS
                                        </h5>
                                    </div>

                                    <!-- Blog Title -->
                                    <div class="form-group row mb-4">
                                        <label for="blog-title"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-heading me-2"></i> Title
                                        </label>
                                        <div class="col-sm-9">
                                            <input type="text" class="form-control form-control-lg" id="blog-title"
                                                name="blogTitle" value="<%= blog.blogTitle %>"
                                                placeholder="The headline that stops scrolls..." required autofocus />
                                        </div>
                                    </div>

                                    <!-- Current Image Preview + Upload New -->
                                    <div class="form-group row mb-4">
                                        <label for="blog-image"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-image me-2"></i> Featured Image
                                        </label>
                                        <div class="col-sm-9">

                                            <!-- ★ Current Image Preview ★ -->
                                            <div class="mb-3 p-3 bg-light rounded-3 border">
                                                <p class="text-muted small mb-2 fw-semibold">
                                                    <i class="fas fa-eye me-1"></i> Current Image:
                                                </p>
                                                <img src="/<%= blog.blogImage %>" alt="Current Blog Image"
                                                    class="rounded-3 shadow-sm"
                                                    style="max-height: 180px; max-width: 100%; object-fit: cover;" />
                                            </div>

                                            <!-- New Image Upload (Optional) -->
                                            <input type="file" class="form-control" id="blog-image" name="blogImage"
                                                accept="image/*" />

                                            <small class="text-muted mt-1 d-block">
                                                <i class="fas fa-info-circle me-1"></i>
                                                Leave empty to keep the current image. Upload only to replace.
                                            </small>

                                        </div>
                                    </div>

                                    <!-- Category -->
                                    <div class="form-group row mb-4">
                                        <label for="blog-category"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-folder-open me-2"></i> Category
                                        </label>
                                        <div class="col-sm-9">
                                            <select class="form-select" id="blog-category" name="blogCategory" required>
                                                <option disabled>Choose category...</option>
                                                <option value="technology" <%=blog.blogCategory==='technology'
                                                    ? 'selected' : '' %>>
                                                    Technology
                                                </option>
                                                <option value="lifestyle" <%=blog.blogCategory==='lifestyle'
                                                    ? 'selected' : '' %>>
                                                    Lifestyle
                                                </option>
                                                <option value="business" <%=blog.blogCategory==='business' ? 'selected'
                                                    : '' %>>
                                                    Business
                                                </option>
                                                <option value="health" <%=blog.blogCategory==='health' ? 'selected' : ''
                                                    %>>
                                                    Health & Wellness
                                                </option>
                                                <option value="travel" <%=blog.blogCategory==='travel' ? 'selected' : ''
                                                    %>>
                                                    Travel
                                                </option>
                                                <option value="education" <%=blog.blogCategory==='education'
                                                    ? 'selected' : '' %>>
                                                    Education
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Tags -->
                                    <div class="form-group row mb-4">
                                        <label for="blog-tags"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-tags me-2"></i> Tags
                                        </label>
                                        <div class="col-sm-9">
                                            <input type="text" class="form-control" id="blog-tags" name="blogTags"
                                                value="<%= blog.blogTags %>" placeholder="AI, Productivity, Future" />
                                        </div>
                                    </div>

                                    <!-- Excerpt -->
                                    <div class="form-group row mb-4">
                                        <label for="blog-excerpt"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-align-left me-2"></i> Excerpt
                                        </label>
                                        <div class="col-sm-9">
                                            <textarea class="form-control" id="blog-excerpt" name="blogExcerpt" rows="3"
                                                placeholder="A gripping preview shown in listings..."
                                                required><%= blog.blogExcerpt %></textarea>
                                        </div>
                                    </div>

                                    <!-- Main Content -->
                                    <div class="form-group row mb-5">
                                        <label for="blog-content"
                                            class="col-sm-3 text-end control-label col-form-label fw-semibold">
                                            <i class="fas fa-pen-nib me-2"></i> Content
                                        </label>
                                        <div class="col-sm-9">
                                            <textarea class="form-control" id="blog-content" name="blogContent"
                                                rows="12" placeholder="Start writing your legacy here..."
                                                required><%= blog.blogContent %></textarea>
                                        </div>
                                    </div>

                                </div>

                                <!-- Submit Bar -->
                                <div class="border-top pt-4">
                                    <div class="card-body pt-0">
                                        <div class="d-flex justify-content-center gap-3">

                                            <!-- Cancel Button -->
                                            <a href="/blog"
                                                class="btn btn-outline-secondary px-4 py-3 fw-bold rounded-pill">
                                                <i class="fas fa-arrow-left me-2"></i> CANCEL
                                            </a>

                                            <!-- Update Button -->
                                            <button type="submit"
                                                class="btn btn-primary px-5 py-3 fw-bold rounded-pill">
                                                <i class="fas fa-save me-2"></i> UPDATE BLOG
                                            </button>

                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>

                        <div class="text-center mt-4">
                            <small class="text-muted d-block">
                                Editing: "<strong>
                                    <%= blog.blogTitle %>
                                </strong>"
                                &nbsp;•&nbsp;
                                Last updated: <%= new Date(blog.updatedAt).toLocaleDateString('en-US', { month: 'short'
                                    , day: 'numeric' , year: 'numeric' , hour: '2-digit' , minute: '2-digit' }) %>
                            </small>
                        </div>

                    </div>
                </div>
            </div>
        </div>


    </div>
    <!-- Bootstrap JavaScript Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>
</body>

</html>